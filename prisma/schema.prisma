generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CLIENTE
}

enum DocumentType {
  DNI
  RUC
}

enum OrderStatus {
  PENDIENTE
  PROCESANDO
  ENVIADO
  COMPLETADO
  CANCELADO
}

enum PaymentMethod {
  YAPE
  PLIN
  TARJETA
  TRANSFERENCIA
}

enum PaymentStatus {
  PENDIENTE
  APROBADO
  FALLIDO
}

model User {
  id             String       @id @default(uuid())
  nombre_completo String
  tipo_documento  DocumentType
  num_documento   String
  email          String       @unique
  password_hash  String
  telefono       String?
  direccion_defecto String?
  rol            Role         @default(CLIENTE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  orders         Order[]
  wishlist       Wishlist[]
}

model Brand {
  id        String    @id @default(uuid())
  nombre    String
  logo_url  String?
  estado    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

model Category {
  id        String    @id @default(uuid())
  nombre    String
  estado    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

model Product {
  id          String    @id @default(uuid())
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brandId     String?
  brand       Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  nombre      String
  sku         String    @unique
  descripcion String?
  precio      Decimal   @db.Decimal(10, 2)
  enOferta    Boolean   @default(false)
  precioOferta Decimal? @db.Decimal(10, 2)
  mostrarPrecio Boolean @default(true)
  stock       Int       @default(0)
  imagen_url  String?
  estado      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orderItems  OrderItem[]
  wishlist    Wishlist[]
}

model Order {
  id              String      @id @default(uuid())
  userId          String?     // <-- El signo de interrogación es la clave
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull) // <-- Relación opcional
  total           Decimal     @db.Decimal(10, 2)
  estado_pedido   OrderStatus @default(PENDIENTE)
  direccion_envio String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  orderItems      OrderItem[]
  payment         Payment?
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  cantidad        Int
  precio_unitario Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Payment {
  id             String        @id @default(uuid())
  orderId        String        @unique
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  metodo_pago    PaymentMethod
  estado_pago    PaymentStatus @default(PENDIENTE)
  transaccion_id String?
  comprobante_url String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Banner {
  id              String   @id @default(uuid())
  titulo          String
  imagen_url      String
  enlace_opcional String?
  activo          Boolean  @default(true)
  orden           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Wishlist {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, productId])
}

enum ComplaintStatus {
  PENDIENTE
  EN_PROCESO
  RESUELTO
}

enum ComplaintType {
  RECLAMO
  QUEJA
}

enum ItemType {
  PRODUCTO
  SERVICIO
}

model Complaint {
  id              String          @id @default(uuid())
  nombres         String
  documento       String
  email           String
  telefono        String?
  domicilio       String
  
  tipoBien        ItemType        @default(PRODUCTO)
  montoReclamado  Decimal?        @db.Decimal(10, 2)
  descripcionBien String

  tipoReclamo     ComplaintType   @default(RECLAMO)
  detalle         String
  pedido          String

  estado          ComplaintStatus @default(PENDIENTE)
  respuesta       String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}
